@using Microsoft.AspNetCore.Identity
@using Control_flota.Models.Login;

@inject SignInManager<Usuario> SignInManager

@{
    ViewData["Title"] = "FleetOps Pro - Control de Flota Vehicular";
}

<style>

    footer {
    display: none !important;
    }
    .landing-page {
        min-height: 100vh;
        background-color: #ffffff;
        color: #1a1a1a;
        font-family: system-ui, -apple-system, sans-serif;
    }
    
    .hero-section {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        min-height: 80vh;
        text-align: center;
    }
    
    .hero-content {
        max-width: 1000px;
        width: 100%;
    }

    .hero-icon {
        color: #0056b3;
        font-size: 3.5rem;
        margin-bottom: 20px;
        display: block;
    }
    
    .hero-content h1 {
        font-size: 3rem;
        font-weight: 700;
        color: #002d62;
        margin-bottom: 15px;
        letter-spacing: -0.5px;
    }
    
    .hero-content p {
        font-size: 1.2rem;
        color: #4a5568;
        margin-bottom: 10px;
    }
    
    .btn-login-landing {
        display: inline-block;
        padding: 12px 35px;
        background-color: #0056b3;
        color: #ffffff;
        border: 2px solid #0056b3;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 20px;
        transition: all 0.2s ease-in-out;
    }
    
    .btn-login-landing:hover {
        background-color: #004085;
        border-color: #004085;
        color: #ffffff;
    }
    
    .features-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 24px;
        margin-top: 60px;
        border-top: 1px solid #e2e8f0;
        padding-top: 40px;
    }
    
    .feature-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        padding: 25px;
        border-radius: 8px;
        text-align: center;
        transition: border-color 0.2s ease;
    }

    .feature-card:hover {
        border-color: #0056b3;
    }
    
    .feature-card i {
        color: #0056b3;
        font-size: 2rem;
        margin-bottom: 15px;
    }
    
    .feature-card h3 {
        font-size: 1.15rem;
        font-weight: 600;
        color: #002d62;
        margin-bottom: 10px;
    }
    
    .feature-card p {
        font-size: 0.9rem;
        color: #64748b;
        margin-bottom: 0;
    }

    /* Estilos para el estado Autenticado */
    .dashboard-welcome {
        max-width: 600px;
        margin: 80px auto;
        padding: 40px 20px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background-color: #ffffff;
    }
    .dashboard-welcome h1 {
        color: #002d62;
        font-weight: 700;
    }
</style>

@if (SignInManager.IsSignedIn(User))
{
    <!-- Vista simplificada para usuario logueado -->
    <div class="container text-center">
        <div class="dashboard-welcome">
            <i class="fa-regular fa-circle-check text-success mb-3" style="font-size: 3rem;"></i>
            <h1>Bienvenido, @User.Identity?.Name!</h1>
            <p class="text-muted lead">Sistema activo. Selecciona una opción en el menú lateral para comenzar a operar.</p>
        </div>
    </div>
}
else
{
    <!-- Landing page limpia (Blanco, Azul y Negro) -->
    <div class="landing-page">
        <div class="hero-section">
            <div class="hero-content">
                <i class="fa-solid fa-truck hero-icon"></i>
                <h1>FleetOps Pro</h1>
                <p>Sistema completo de control de flota vehicular</p>
                <p style="font-size: 1rem; color: #64748b; margin-bottom: 10px;">
                    Gestiona conductores, unidades, órdenes de servicio y logística general.
                </p>
                
                <div class="features-section">
                    <div class="feature-card">
                        <i class="fa-solid fa-truck"></i>
                        <h3>Gestión de Flota</h3>
                        <p>Administra tu flota de vehículos de forma eficiente.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fa-regular fa-user"></i>
                        <h3>Conductores</h3>
                        <p>Control completo de conductores y asignaciones.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fa-regular fa-paper-plane"></i>
                        <h3>Despacho</h3>
                        <p>Gestiona órdenes de servicio y despachos.</p>
                    </div>
                    <div class="feature-card">
                        <i class="fa-solid fa-location-dot"></i>
                        <h3>Rastreo</h3>
                        <p>Localización en tiempo real de vehículos.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


@model Control_flota.Models.Operaciones.Unidad

@{
    ViewData["Title"] = "Registrar Nueva Unidad";
}

<h1>Registrar Nueva Unidad</h1>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label for="Placa">Placa</label>
        <input type="text" asp-for="Placa" class="form-control" />
        <span asp-validation-for="Placa" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Tipo">Tipo</label>
        <input type="text" asp-for="Tipo" class="form-control" />
        <span asp-validation-for="Tipo" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Marca">Marca</label>
        <input type="text" asp-for="Marca" class="form-control" />
        <span asp-validation-for="Marca" class="text-danger"></span>
    </div>
    <div class="form-group">
    <label for="Modelo">Modelo</label>
    <input type="text" asp-for="Modelo" class="form-control" />
    <span asp-validation-for="Modelo" class="text-danger"></span>
    
    </div>
    <div class="form-group">
    <label for="Anio">Año</label>
    <input type="number" asp-for="Anio" class="form-control" min="1990" max="2100" />
    <span asp-validation-for="Anio" class="text-danger"></span>
</div>
    <div class="form-group">
        <label for="CapacidadKg">Capacidad (kg)</label>
        <input type="number" asp-for="CapacidadKg" class="form-control" />
        <span asp-validation-for="CapacidadKg" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="VencimientoSoat">Vencimiento SOAT</label>
        <input type="date" asp-for="VencimientoSoat" class="form-control" />
        <span asp-validation-for="VencimientoSoat" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="VencimientoRevisionTecnica">Vencimiento Revisión Técnica</label>
        <input type="date" asp-for="VencimientoRevisionTecnica" class="form-control" />
        <span asp-validation-for="VencimientoRevisionTecnica" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="VencimientoMtc">Vencimiento MTC</label>
        <input type="date" asp-for="VencimientoMtc" class="form-control" />
        <span asp-validation-for="VencimientoMtc" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Registrar</button>
</form>
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}